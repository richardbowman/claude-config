#!/usr/bin/env bash
# wtcc — fetch + fast-forward main, then launch Claude Code in a new worktree
#        branched off main (not off whatever branch is currently checked out).
# Usage: wtcc [name]  (defaults to work-YYYYMMDD-HHMMSS if omitted)

set -euo pipefail

name="${1:-work-$(date +%Y%m%d-%H%M%S)}"

echo "==> wtcc: starting worktree '$name'"

# Check for claude-config updates
config_repo="$HOME/claude-config"
echo "--> checking claude-config for updates..."
if git -C "$config_repo" fetch origin -q 2>/dev/null; then
  behind=$(git -C "$config_repo" rev-list HEAD..origin/main --count 2>/dev/null || echo 0)
  if [ "$behind" -gt 0 ]; then
    echo "⚠️  claude-config is $behind commit(s) behind origin — run: cd $config_repo && git pull && ./bootstrap.sh"
  else
    echo "    claude-config is up to date"
  fi
else
  echo "    could not reach origin, skipping update check"
fi

echo "--> fast-forwarding main..."
wt-ff-main || exit 1

# Determine default branch and repo root
default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
default_branch="${default_branch:-main}"
repo_root=$(git rev-parse --show-toplevel)

# Create worktree off main, at the same path claude --worktree would use
worktree_path="$repo_root/.claude/worktrees/$name"
mkdir -p "$repo_root/.claude/worktrees"
echo "--> creating worktree at $worktree_path (branch: $name, base: $default_branch)..."
git worktree add -b "$name" "$worktree_path" "$default_branch"

echo "--> tagging cmux workspace..."
cmux workspace-action rename --title "$name" 2>/dev/null || true
cmux workspace-action set-description --description "$worktree_path" 2>/dev/null || true

echo "--> launching Claude Code..."
cd "$worktree_path"
claude --permission-mode acceptEdits "/worktree-bootstrap"
