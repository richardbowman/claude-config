#!/usr/bin/env bash
# wtadd — safe git worktree creation: fetch + fast-forward main first,
# then create the worktree. Prevents branching off a stale base.
# Usage: wtadd <path> [<branch>] [extra git worktree add args]

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: wtadd <path> [<branch>] [extra git worktree add args]" >&2
  exit 1
fi

wt-ff-main || exit 1
git worktree add "$@"

# Launch Claude in the new worktree if stdout is a terminal
wt_path="$1"
if [ -t 1 ] && command -v claude &>/dev/null; then
  cd "$wt_path" && exec claude
fi
