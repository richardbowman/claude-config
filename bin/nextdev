#!/usr/bin/env bash
# nextdev — scoped local dev-server manager.
#
# Each instance is keyed by its absolute cwd. Starting from a worktree
# creates a distinct instance; commands only ever touch processes this
# script started. Never uses pkill/killall/fuser/wildcard patterns.
#
# Commands:
#   start    [--port N] [--pm npm|pnpm|yarn|bun] [--cmd "..."]
#   stop     [--force]
#   restart  [--port N] [--pm ...] [--cmd ...]
#   status              # cwd instance only
#   list                # every registered instance
#   logs     [-f] [-n N]
#   clean               # remove registrations whose pid is gone
#   doctor              # show environment checks
#
# Runs on Linux, macOS, and WSL. Plain bash, no dependencies beyond
# coreutils + pgrep.

set -euo pipefail

VERSION=0.1.0
STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/nextdev"
mkdir -p "$STATE_ROOT"

###############################################################################
# Helpers
###############################################################################

die() { echo "nextdev: $*" >&2; exit 1; }
warn() { echo "nextdev: $*" >&2; }

hash_path() {
  if command -v sha1sum >/dev/null 2>&1; then
    printf '%s' "$1" | sha1sum | cut -c1-12
  elif command -v shasum >/dev/null 2>&1; then
    printf '%s' "$1" | shasum | cut -c1-12
  else
    die "need sha1sum or shasum on PATH"
  fi
}

instance_dir_for_cwd() {
  printf '%s/%s' "$STATE_ROOT" "$(hash_path "$(pwd -P)")"
}

port_in_use() {
  local p="$1"
  if command -v ss >/dev/null 2>&1; then
    ss -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}$"
  elif command -v lsof >/dev/null 2>&1; then
    lsof -iTCP:"$p" -sTCP:LISTEN -P -n >/dev/null 2>&1
  elif command -v netstat >/dev/null 2>&1; then
    netstat -tln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${p}$"
  else
    return 1
  fi
}

find_free_port() {
  local start="${1:-3000}" p
  for (( p=start; p<start+200; p++ )); do
    port_in_use "$p" || { echo "$p"; return 0; }
  done
  die "no free port found in ${start}-$((start+199))"
}

# A pid is "ours" only if it still exists AND its command looks like node/next.
verify_pid() {
  local pid="$1"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  local args
  args="$(ps -p "$pid" -o args= 2>/dev/null || true)"
  [[ "$args" == *node* || "$args" == *next* || "$args" == *npm* || "$args" == *pnpm* || "$args" == *yarn* || "$args" == *bun* ]]
}

detect_pm() {
  if [[ -f pnpm-lock.yaml ]]; then echo pnpm
  elif [[ -f yarn.lock ]]; then echo yarn
  elif [[ -f bun.lockb || -f bun.lock ]]; then echo bun
  elif [[ -f package.json ]]; then echo npm
  else echo ""
  fi
}

pm_dev_cmd() {
  case "$1" in
    pnpm) echo "pnpm dev" ;;
    yarn) echo "yarn dev" ;;
    bun)  echo "bun run dev" ;;
    npm)  echo "npm run dev" ;;
    *)    echo "" ;;
  esac
}

stop_pid_tree() {
  local pid="$1" sig="${2:-TERM}"
  [[ -n "$pid" ]] || return 0
  # Kill children first (so the parent doesn't respawn them)
  local child
  for child in $(pgrep -P "$pid" 2>/dev/null || true); do
    stop_pid_tree "$child" "$sig"
  done
  kill -"$sig" "$pid" 2>/dev/null || true
}

wait_for_exit() {
  local pid="$1" timeout="${2:-10}" i
  for (( i=0; i<timeout*10; i++ )); do
    kill -0 "$pid" 2>/dev/null || return 0
    sleep 0.1
  done
  return 1
}

read_field() {
  local dir="$1" name="$2"
  [[ -f "$dir/$name" ]] && cat "$dir/$name" || echo ""
}

###############################################################################
# Commands
###############################################################################

cmd_start() {
  local port="" pm="" cmd=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      --pm)   pm="$2";   shift 2 ;;
      --cmd)  cmd="$2";  shift 2 ;;
      -h|--help) grep '^#' "$0" | sed 's/^# \?//'; exit 0 ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  [[ -f package.json ]] || die "no package.json in $(pwd -P)"

  local dir
  dir="$(instance_dir_for_cwd)"
  mkdir -p "$dir"

  if [[ -f "$dir/pid" ]]; then
    local existing
    existing="$(cat "$dir/pid")"
    if verify_pid "$existing"; then
      echo "Already running: pid=$existing port=$(read_field "$dir" port)"
      echo "Use 'nextdev restart' to replace it."
      exit 1
    fi
    rm -f "$dir/pid"
  fi

  if [[ -z "$cmd" ]]; then
    [[ -z "$pm" ]] && pm="$(detect_pm)"
    [[ -n "$pm" ]] || die "no package manager detected (no lockfile or package.json)"
    cmd="$(pm_dev_cmd "$pm")"
  fi

  if [[ -z "$port" ]]; then
    port="${PORT:-}"
  fi
  if [[ -z "$port" ]]; then
    port="$(find_free_port 3000)"
  elif port_in_use "$port"; then
    die "port $port is already in use"
  fi

  local cwd
  cwd="$(pwd -P)"
  printf '%s\n' "$cwd"  > "$dir/cwd"
  printf '%s\n' "$port" > "$dir/port"
  printf '%s\n' "$cmd"  > "$dir/command"
  date -u +%Y-%m-%dT%H:%M:%SZ > "$dir/started_at"

  if [[ -f "$dir/dev.log" ]]; then
    mv "$dir/dev.log" "$dir/dev.log.prev"
  fi

  # Launch detached. Exporting PORT is the Next.js-standard way to set the
  # listen port; --cmd override can also use it.
  (
    cd "$cwd"
    PORT="$port" nohup bash -lc "$cmd" >"$dir/dev.log" 2>&1 &
    echo $! > "$dir/pid"
    disown || true
  )

  local pid
  pid="$(cat "$dir/pid")"
  sleep 0.2
  if ! kill -0 "$pid" 2>/dev/null; then
    warn "process exited immediately — check $dir/dev.log"
    tail -n 20 "$dir/dev.log" >&2 || true
    exit 1
  fi

  cat <<EOF
Started ${cwd##*/} (nextdev)
  pid:  $pid
  port: $port
  cmd:  $cmd
  url:  http://localhost:$port
  logs: $dir/dev.log
EOF
}

cmd_stop() {
  local force=0
  [[ "${1:-}" == "--force" ]] && force=1

  local dir
  dir="$(instance_dir_for_cwd)"
  if [[ ! -f "$dir/pid" ]]; then
    echo "Not running from $(pwd -P)"
    return 0
  fi

  local pid
  pid="$(cat "$dir/pid")"

  if (( ! force )) && ! verify_pid "$pid"; then
    warn "pid $pid no longer looks like node/next; refusing to kill"
    warn "use 'nextdev stop --force' to override, or 'nextdev clean' to drop the registration"
    return 1
  fi

  echo "Stopping pid=$pid (tree) ..."
  stop_pid_tree "$pid" TERM
  if ! wait_for_exit "$pid" 10; then
    warn "did not exit on TERM; sending KILL"
    stop_pid_tree "$pid" KILL
    wait_for_exit "$pid" 5 || warn "pid $pid still alive"
  fi
  rm -f "$dir/pid"
  echo "Stopped."
}

cmd_restart() {
  cmd_stop || true
  cmd_start "$@"
}

cmd_status() {
  local dir
  dir="$(instance_dir_for_cwd)"
  if [[ ! -d "$dir" ]]; then
    echo "No instance registered for $(pwd -P)"
    return 0
  fi
  local pid port cwd cmd started
  pid="$(read_field "$dir" pid)"
  port="$(read_field "$dir" port)"
  cwd="$(read_field "$dir" cwd)"
  cmd="$(read_field "$dir" command)"
  started="$(read_field "$dir" started_at)"

  local state="stopped"
  if [[ -n "$pid" ]] && verify_pid "$pid"; then
    state="running"
  fi

  cat <<EOF
state:   $state
cwd:     $cwd
pid:     ${pid:-—}
port:    ${port:-—}
cmd:     ${cmd:-—}
started: ${started:-—}
logs:    $dir/dev.log
EOF
}

cmd_list() {
  printf '%-10s  %-6s  %-6s  %s\n' "STATE" "PID" "PORT" "CWD"
  local d
  shopt -s nullglob
  for d in "$STATE_ROOT"/*/; do
    local pid port cwd state
    pid="$(read_field "$d" pid)"
    port="$(read_field "$d" port)"
    cwd="$(read_field "$d" cwd)"
    state="stopped"
    if [[ -n "$pid" ]] && verify_pid "$pid"; then
      state="running"
    fi
    printf '%-10s  %-6s  %-6s  %s\n' "$state" "${pid:--}" "${port:--}" "${cwd:-?}"
  done
  shopt -u nullglob
}

cmd_logs() {
  local follow=0 n=200
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f) follow=1; shift ;;
      -n) n="$2"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  local dir log
  dir="$(instance_dir_for_cwd)"
  log="$dir/dev.log"
  [[ -f "$log" ]] || die "no logs at $log"
  if (( follow )); then
    tail -n "$n" -f "$log"
  else
    tail -n "$n" "$log"
  fi
}

cmd_clean() {
  local d removed=0
  shopt -s nullglob
  for d in "$STATE_ROOT"/*/; do
    local pid
    pid="$(read_field "$d" pid)"
    if [[ -z "$pid" ]] || ! verify_pid "$pid"; then
      rm -rf "$d"
      removed=$(( removed + 1 ))
    fi
  done
  shopt -u nullglob
  echo "Removed $removed stale registration(s)."
}

cmd_doctor() {
  echo "nextdev $VERSION"
  echo "state root: $STATE_ROOT"
  echo "bash:       $BASH_VERSION"
  command -v node   >/dev/null && echo "node:       $(node --version)"   || echo "node:       NOT FOUND"
  command -v npm    >/dev/null && echo "npm:        $(npm --version)"    || true
  command -v pnpm   >/dev/null && echo "pnpm:       $(pnpm --version)"   || true
  command -v yarn   >/dev/null && echo "yarn:       $(yarn --version)"   || true
  command -v bun    >/dev/null && echo "bun:        $(bun --version)"    || true
  command -v pgrep  >/dev/null && echo "pgrep:      ok"                  || echo "pgrep:      NOT FOUND (required)"
  command -v ss     >/dev/null && echo "port check: ss"
  command -v lsof   >/dev/null && echo "port check: lsof"
  command -v netstat>/dev/null && echo "port check: netstat"
}

###############################################################################
# Entry
###############################################################################

sub="${1:-}"
shift || true
case "$sub" in
  start)   cmd_start "$@" ;;
  stop)    cmd_stop "$@" ;;
  restart) cmd_restart "$@" ;;
  status)  cmd_status "$@" ;;
  list|ls) cmd_list "$@" ;;
  logs)    cmd_logs "$@" ;;
  clean)   cmd_clean "$@" ;;
  doctor)  cmd_doctor "$@" ;;
  -v|--version) echo "nextdev $VERSION" ;;
  -h|--help|"") grep '^#' "$0" | sed 's/^# \?//'; ;;
  *) die "unknown command: $sub (try --help)" ;;
esac
