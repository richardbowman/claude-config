#!/usr/bin/env bash
# wt-ff-main — fetch origin and fast-forward local main if behind.
# Used by wtadd and wtcc. Exits non-zero on failure with a clear message.

set -euo pipefail

echo "==> fetching origin..." && git fetch origin || exit 1

default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
default_branch=${default_branch:-main}

# Check if local main is behind origin/main
behind=$(git rev-list "${default_branch}..origin/${default_branch}" --count 2>/dev/null)
if [ "${behind:-0}" -gt 0 ]; then
  echo "==> fast-forwarding ${behind} commit(s) from origin/${default_branch}..."

  # Advance the local branch ref directly — no checkout needed.
  # This works even when main is checked out in another worktree.
  if ! git branch -f "$default_branch" "origin/${default_branch}" 2>/dev/null; then
    echo "!! fast-forward failed — resolve divergence before creating a worktree" >&2
    exit 1
  fi
else
  echo "==> local ${default_branch} is up to date"
fi

exit 0
