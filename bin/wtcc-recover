#!/usr/bin/env bash
# wtcc-recover — relaunch Claude in all worktree workspaces after a cmux crash.
#
# After a crash cmux restores tabs but loses cwd — so tabs that should be in
# .claude/worktrees/<name> land back at the repo root. This script finds those
# tabs by matching their title against existing worktree directories, then opens
# a new workspace at the correct path with Claude running.

set -euo pipefail

cmux rpc workspace.list 2>/dev/null | python3 -c "
import sys, json, os, subprocess

data = json.load(sys.stdin)
home = os.environ.get('HOME', '')

recovered = 0
skipped = []

for ws in data.get('workspaces', []):
    title = ws.get('title', '').strip()
    if not title:
        continue

    # Find a worktree directory whose basename matches this title
    result = subprocess.run(
        ['find', home, '-maxdepth', '6', '-path', f'*/.claude/worktrees/{title}', '-type', 'd'],
        capture_output=True, text=True
    )
    paths = [p for p in result.stdout.strip().splitlines() if p]

    if not paths:
        continue

    cwd = paths[0]
    print(f'--> recovering: {title}')
    print(f'    path: {cwd}')
    subprocess.run([
        'cmux', 'new-workspace',
        '--name', title,
        '--description', cwd,
        '--cwd', cwd,
        '--command', 'claude --permission-mode acceptEdits'
    ])
    recovered += 1

print(f'\nOpened {recovered} workspace(s). Type /resume in each to pick up where you left off.')
if recovered:
    print('You can close the old tabs (same title, no Claude running) manually.')
"
