{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "us.anthropic.claude-sonnet-4-6",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/claude-config/bin/statusline-command.sh"
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "vercel-plugin@vercel": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/claude-config/bin/check-aws-auth",
            "statusMessage": "Checking AWS authentication..."
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      },
      "autoUpdate": true
    }
  }
}
